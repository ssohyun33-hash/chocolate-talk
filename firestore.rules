rules_version = '2';
service cloudfirestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to extract incoming and existing database data safely
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Check if ID is structured properly to prevent Resource Poisoning or Wallet Drain
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Check if user is a member of the requested chat
    function isMemberOfChat(chatId) {
      return exists(/databases/$(database)/documents/chats/$(chatId)/members/$(request.auth.uid));
    }

    // Check if user is the host of the requested chat
    function isHostOfChat(chatId) {
      return exists(/databases/$(database)/documents/chats/$(chatId))
        && get(/databases/$(database)/documents/chats/$(chatId)).data.hostId == request.auth.uid;
    }

    // Check if user is the system admin
    function isAdmin() {
      return isSignedIn() 
        && 'token' in request.auth
        && 'email' in request.auth.token
        && (
          request.auth.token.email == 'jaein8080@gmail.com'
          || request.auth.uid == 'jaein8080@gmail.com'
          || request.auth.uid == 'jaein8080'
          || request.auth.token.email == 'admin@chocolatetalk.local'
        );
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read, list: if isSignedIn() || isAdmin();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();

      // Friends Subcollection: Saved persistently per user
      match /friends/{friendId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Joined Chats Subcollection: Tracking chats the user belongs to persistently
      match /joinedChats/{joinedChatId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Chats Collection ---
    match /chats/{chatId} {
      allow read, list: if isSignedIn() || isAdmin();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() || isAdmin();

      // Members Subcollection inside a Chat
      match /members/{memberId} {
        allow read, list: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }

      // Messages Subcollection inside a Chat
      match /messages/{messageId} {
        allow read, list: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }
    }

    // --- Usernames Collection (Uniqueness claims) ---
    match /usernames/{username} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidId(username);
      allow delete: if isAdmin();
    }

    // --- Reports Collection ---
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // --- Bans Collection ---
    match /bans/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Announcements Collection ---
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Default Deny Catch-All placed safely at the bottom
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
